
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}
        

model User {
  id          String   @id @default(uuid())
  firebaseUid String   @unique
  email       String
  createdAt   DateTime @default(now())

  jobs        Job[]
}

model Job {
  id           String   @id @default(uuid())
  userId       String
  title        String
  description  String
  requirements Json?
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id])
  resumes      Resume[]
}

model Resume {
  id           String   @id @default(uuid())
  jobId        String

  storagePath  String
  status       ResumeStatus @default(PENDING)

  uploadedAt   DateTime?
  createdAt    DateTime @default(now())

  job          Job      @relation(fields: [jobId], references: [id])
  parsed       ParsedResume?
  results      ScreeningResult[]
}

enum ResumeStatus {
  PENDING
  UPLOADED
  PARSED
  EMBEDDED
  READY
}


model ParsedResume {
  id         String   @id @default(uuid())
  resumeId   String   @unique
  rawText    String
  parsedJson Json
  createdAt  DateTime @default(now())

  resume     Resume   @relation(fields: [resumeId], references: [id])
}

model ScreeningResult {
  id               String   @id @default(uuid())
  resumeId         String
  jobId            String
  skillScore       Float
  experienceScore  Float
  semanticScore    Float
  finalScore       Float
  explanation      String
  modelVersion     String
  createdAt        DateTime @default(now())

  resume           Resume   @relation(fields: [resumeId], references: [id])
}
