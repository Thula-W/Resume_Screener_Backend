
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}
        

model User {
  id          String   @id @default(uuid())
  firebaseUid String   @unique
  email       String
  createdAt   DateTime @default(now())

  jobs        Job[]
}

model Job {
  id           String   @id @default(uuid())
  userId       String
  title        String
  description  String
  requirements Json?
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id])
  resumes      Resume[]
}

model Resume {
  id           String   @id @default(uuid())
  jobId        String

  storagePath  String
  status       ResumeStatus @default(PENDING)

  uploadedAt   DateTime?
  createdAt    DateTime @default(now())
  batchId      String?
  parsedJson   Json?

  batch        UploadBatch? @relation(fields: [batchId], references: [id])
  job          Job      @relation(fields: [jobId], references: [id])
  parsed       ParsedResume?
  results      ScreeningResult[]
   failures  BatchFailure[]
}

enum ResumeStatus {
  PENDING
  UPLOADED
  PARSED
  EMBEDDED
  READY
}

model UploadBatch {
  id              String        @id @default(uuid())
  jobId           String
  totalResumes    Int
  processedCount  Int           @default(0)
  failedCount     Int           @default(0)
  status          BatchStatus   @default(PROCESSING)
  createdAt       DateTime      @default(now())
  completedAt     DateTime?

  resumes         Resume[]
  failures        BatchFailure[]
}

model BatchFailure {
  id        String   @id @default(uuid())
  batchId   String
  resumeId  String
  reason    String
  createdAt DateTime @default(now())

  batch     UploadBatch @relation(fields: [batchId], references: [id])
  resume    Resume      @relation(fields: [resumeId], references: [id])
}

enum BatchStatus {
  PROCESSING
  COMPLETED
}

model ParsedResume {
  id         String   @id @default(uuid())
  resumeId   String   @unique
  rawText    String
  parsedJson Json
  createdAt  DateTime @default(now())

  resume     Resume   @relation(fields: [resumeId], references: [id])
}

model ScreeningResult {
  id               String   @id @default(uuid())
  resumeId         String
  jobId            String
  skillScore       Float
  experienceScore  Float
  semanticScore    Float
  finalScore       Float
  explanation      String
  modelVersion     String
  createdAt        DateTime @default(now())

  resume           Resume   @relation(fields: [resumeId], references: [id])
}
